local SpeedBtn = CreateBtn("CHẠY NHANH: OFF", UDim2.new(0.05, 0, 0.65, 0))

local kill_stay_on, speed_on = false, false

-- 4. LOGIC BẬT/TẮT MENU CHÍNH
local isMainVisible = false
MiniBtn.MouseButton1Click:Connect(function()
    isMainVisible = not isMainVisible
    Main.Visible = isMainVisible
    -- Hiệu ứng nút mini
    TweenService:Create(MiniBtn, TweenInfo.new(0.2), {BackgroundColor3 = isMainVisible and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 0, 0)}):Play()
end)

-- 5. HỆ THỐNG RGB TOÀN DIỆN & TỰ ĐỘNG
RunService.Stepped:Connect(function()
    local color = Color3.fromHSV(tick() % 3 / 3, 1, 1)
    
    -- Màu cho nút Mini
    MiniStroke.Color = color
    
    -- Màu cho Menu chính
    MainStroke.Color = color
    Title.TextColor3 = color
    KillStayBtn.TextColor3 = color
    SpeedBtn.TextColor3 = color

    if speed_on and Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = 110
    end

    -- ESP
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Player and v.Character then
            local hl = v.Character:FindFirstChild("LinhESP") or Instance.new("Highlight", v.Character)
            hl.Name = "LinhESP"
            hl.FillColor = color
            hl.OutlineColor = Color3.new(1, 1, 1)
            hl.DepthMode = 0
        end
    end
end)

-- 6. TĂNG TẦM ĐÁNH VÀ CHÉM CẢ MAP
RunService.RenderStepped:Connect(function()
    pcall(function()
        local char = Player.Character
        local tool = char:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
        if not tool or not kill_stay_on then return end
        
        tool.Parent = char
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Player and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                local targetHRP = v.Character.HumanoidRootPart
                local distance = (char.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                
                -- TẦM ĐÁNH CỰC XA
                if distance < 8000 then 
                    local originalCF = targetHRP.CFrame
                    targetHRP.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
                    tool:Activate()
                    task.wait()
                    targetHRP.CFrame = originalCF
                end
            end
        end
    end)
end)

